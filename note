打流
# 1. 指定MPICH的执行路径（优先级最高），可能需要修改mpich-3.2.1
export PATH=/usr/local/mpich-4.1.3/bin:$PATH

# 2. 加载昇腾CANN工具链的核心环境变量（重中之重！昇腾所有工具/驱动/NPU依赖的环境都在这里），根据cann版本修改
source /home/cann/8.5.0.B095/cann-8.5.0/set_env.sh
source /home/cann/8.5.0.B095/nnal/atb/set_env.sh

# 3. 指定动态链接库路径：追加昇腾CANN的lib64 + MPICH的lib，解决运行时「找不到HCCL库/MPI库」的问题
export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/home/cann/8.5.0.B095/cann/lib64:/usr/local/mpich-4.1.3/lib/

# 4. 进入CANN官方自带的hccl_test工具目录（原生打流工具，比第三方工具精准，昇腾官方唯一推荐）
cd /home/cann/8.5.0.B095/cann/tools/hccl_test/

# 5. 编译hccl_test：指定MPI根目录和CANN根目录，编译出对应的all_reduce_test等二进制文件
make MPI_HOME=/usr/local/mpich-4.1.3 ASCEND_DIR=/home/cann/8.5.0.B095/cann/

# 6. HCCL核心环境变量：设置通信缓冲区大小2048MB，提升大张量通信的稳定性，避免丢包/超时
export HCCL_BUFFSIZE=2048

# 7. 昇腾最核心的网卡绑定！指定HCCL通信走的物理网卡，避免走管理网，这是【带宽跑满的关键】
export HCCL_SOCKET_IFNAME=enp189s0f0

# 8. 核心打流命令：n之后的参数是卡的数量
mpirun -n 32 -hosts 80.48.5.90,80.48.5.89 -ppn 16 ./bin/all_reduce_test -b 1G -e 1G -f 2 -d fp32 -o sum -p 16

# 8卡的：
mpirun -n 16 -hosts 80.5.5.65,80.5.5.69 -ppn 8 ./bin/all_reduce_test -b 1G -e 1G -f 2 -d fp32 -o sum -p 8


